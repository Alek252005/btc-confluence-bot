//@version=6
indicator("BTC Confluence Dashboard v1.1", overlay=true)

htfTimeframe = input.timeframe("60", "HTF timeframe")
minEmaSeparationAtr = input.float(0.15, "Min EMA separation ATR", minval=0.0, step=0.05)
atrLength = input.int(14, "ATR length", minval=1)
pullbackDistanceAtrMultiplier = input.float(0.8, "Pullback distance ATR multiplier", minval=0.0, step=0.1)
showEntryLabels = input.bool(true, "Show entry labels")
signalCooldownBars = input.int(12, "Signal cooldown bars", minval=1)
minActionableLongScore = input.int(70, "Min actionable long score", minval=0, maxval=100)
minActionableShortScore = input.int(70, "Min actionable short score", minval=0, maxval=100)
useAntiLateEntryFilter = input.bool(true, "Use anti late entry filter")
maxCandleDistanceFromEma20Atr = input.float(1.5, "Max candle distance from EMA20 ATR", minval=0.0, step=0.1)
showDebugDots = input.bool(false, "Show debug dots")

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
atr = ta.atr(atrLength)

// Confirmed HTF values only: [1] is inside request.security and lookahead is off.
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEma20 = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 20)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEma50 = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 50)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBullish = htfClose > htfEma20 and htfEma20 > htfEma50
htfBearish = htfClose < htfEma20 and htfEma20 < htfEma50
htfText = htfBullish ? "Bullish" : htfBearish ? "Bearish" : "Neutral"
htfColor = htfBullish ? color.new(color.green, 0) : htfBearish ? color.new(color.red, 0) : color.new(color.gray, 20)

emaFanBullishClean = ema20 > ema50 and ema50 > ema200
emaFanBearishClean = ema20 < ema50 and ema50 < ema200
emaFanText = emaFanBullishClean ? "Bullish clean" : emaFanBearishClean ? "Bearish clean" : "Choppy"
emaFanColor = emaFanBullishClean ? color.new(color.green, 0) : emaFanBearishClean ? color.new(color.red, 0) : color.new(color.yellow, 10)

emaSeparationAtr = atr > 0 ? math.abs(ema20 - ema50) / atr : na
emaSeparationValid = emaSeparationAtr >= minEmaSeparationAtr
emaSeparationText = str.tostring(emaSeparationAtr, "#.##") + " ATR"
emaSeparationColor = emaSeparationValid ? color.new(color.green, 0) : color.new(color.yellow, 10)

atrPercent = close > 0 ? atr / close * 100.0 : na
atrVolatilityLow = atrPercent < 0.05
atrVolatilityNormal = atrPercent >= 0.05 and atrPercent <= 1.5
atrVolatilityHigh = atrPercent > 1.5
atrText = atrVolatilityLow ? "Low" : atrVolatilityHigh ? "High" : "Normal"
atrColor = atrVolatilityNormal ? color.new(color.green, 0) : atrVolatilityLow ? color.new(color.yellow, 10) : color.new(color.red, 0)

priceDistanceFromEma20Atr = atr > 0 ? math.abs(close - ema20) / atr : na
lateLong = useAntiLateEntryFilter and close > ema20 and priceDistanceFromEma20Atr > maxCandleDistanceFromEma20Atr
lateShort = useAntiLateEntryFilter and close < ema20 and priceDistanceFromEma20Atr > maxCandleDistanceFromEma20Atr

pullbackDist = atr * pullbackDistanceAtrMultiplier
nearEma20 = math.abs(close - ema20) <= pullbackDist
nearEma50 = math.abs(close - ema50) <= pullbackDist
pullbackOkRaw = nearEma20 or nearEma50
pullbackOk = pullbackOkRaw and not lateLong and not lateShort
longPullbackZone = pullbackOk and (ema20 > ema50 or htfBullish)
shortPullbackZone = pullbackOk and (ema20 < ema50 or htfBearish)
pullbackText = longPullbackZone and not shortPullbackZone ? "Long zone" : shortPullbackZone and not longPullbackZone ? "Short zone" : pullbackOk ? "Mixed zone" : pullbackOkRaw ? "Late/no zone" : "No zone"
pullbackColor = longPullbackZone and not shortPullbackZone ? color.new(color.green, 0) : shortPullbackZone and not longPullbackZone ? color.new(color.red, 0) : pullbackOk ? color.new(color.yellow, 10) : color.new(color.gray, 30)

bodySize = math.abs(close - open)
avgBody10 = ta.sma(bodySize, 10)
bullishCandle = close > open
bearishCandle = close < open
strongBullishCandle = bullishCandle and bodySize > avgBody10 * 1.2
strongBearishCandle = bearishCandle and bodySize > avgBody10 * 1.2
candleText = strongBullishCandle ? "Strong bullish" : strongBearishCandle ? "Strong bearish" : bullishCandle ? "Bullish" : bearishCandle ? "Bearish" : "Neutral"
candleColor = strongBullishCandle or bullishCandle ? color.new(color.green, 0) : strongBearishCandle or bearishCandle ? color.new(color.red, 0) : color.new(color.gray, 20)

longScore = (
     (htfBullish ? 25 : 0) +
     (emaFanBullishClean ? 20 : 0) +
     (longPullbackZone ? 20 : 0) +
     (strongBullishCandle ? 15 : 0) +
     (atrVolatilityNormal ? 10 : 0) +
     (emaSeparationValid ? 10 : 0)
)

shortScore = (
     (htfBearish ? 25 : 0) +
     (emaFanBearishClean ? 20 : 0) +
     (shortPullbackZone ? 20 : 0) +
     (strongBearishCandle ? 15 : 0) +
     (atrVolatilityNormal ? 10 : 0) +
     (emaSeparationValid ? 10 : 0)
)

biasLong = longScore >= 70 and longScore > shortScore
biasShort = shortScore >= 70 and shortScore > longScore
biasText = biasLong ? "LONG" : biasShort ? "SHORT" : "WAIT"
biasColor = biasLong ? color.new(color.green, 0) : biasShort ? color.new(color.red, 0) : color.new(color.yellow, 10)

longTrendOk = htfBullish and emaFanBullishClean and emaSeparationValid and atrVolatilityNormal
shortTrendOk = htfBearish and emaFanBearishClean and emaSeparationValid and atrVolatilityNormal
longTriggerOk = strongBullishCandle
shortTriggerOk = strongBearishCandle

entryLongRaw = longScore >= minActionableLongScore and longScore > shortScore and longTrendOk and longPullbackZone and longTriggerOk
entryShortRaw = shortScore >= minActionableShortScore and shortScore > longScore and shortTrendOk and shortPullbackZone and shortTriggerOk
entryLong = entryLongRaw and not lateLong
entryShort = entryShortRaw and not lateShort

readyLong = longTrendOk and longPullbackZone and not longTriggerOk and longScore >= minActionableLongScore - 15
readyShort = shortTrendOk and shortPullbackZone and not shortTriggerOk and shortScore >= minActionableShortScore - 15
watchLong = longTrendOk and not longPullbackZone and not entryLong
watchShort = shortTrendOk and not shortPullbackZone and not entryShort
lateLongState = entryLongRaw and lateLong
lateShortState = entryShortRaw and lateShort

actionState = lateLongState ? "LATE LONG" : lateShortState ? "LATE SHORT" : entryLong ? "ENTRY LONG" : entryShort ? "ENTRY SHORT" : readyLong ? "READY LONG" : readyShort ? "READY SHORT" : watchLong ? "WATCH LONG" : watchShort ? "WATCH SHORT" : "WAIT"
actionColor = entryLong or readyLong ? color.new(color.green, 0) : entryShort or readyShort ? color.new(color.red, 0) : watchLong or watchShort or lateLongState or lateShortState ? color.new(color.yellow, 10) : color.new(color.gray, 25)

var int lastLongSignalBar = na
var int lastShortSignalBar = na
longEntryTransition = entryLong and not entryLong[1]
shortEntryTransition = entryShort and not entryShort[1]
longCooldownOk = na(lastLongSignalBar) or bar_index - lastLongSignalBar >= signalCooldownBars
shortCooldownOk = na(lastShortSignalBar) or bar_index - lastShortSignalBar >= signalCooldownBars
longLabelSignal = showEntryLabels and entryLong and (longEntryTransition or longCooldownOk)
shortLabelSignal = showEntryLabels and entryShort and (shortEntryTransition or shortCooldownOk)
longBlockedByCooldown = showEntryLabels and entryLong and not longLabelSignal
shortBlockedByCooldown = showEntryLabels and entryShort and not shortLabelSignal

if longLabelSignal
    lastLongSignalBar := bar_index

if shortLabelSignal
    lastShortSignalBar := bar_index

lastSignalText = na(lastLongSignalBar) and na(lastShortSignalBar) ? "None" : na(lastShortSignalBar) or (not na(lastLongSignalBar) and lastLongSignalBar > lastShortSignalBar) ? "LONG @" + str.tostring(lastLongSignalBar) : "SHORT @" + str.tostring(lastShortSignalBar)

plot(ema20, "EMA20", color=color.new(color.teal, 0), linewidth=1)
plot(ema50, "EMA50", color=color.new(color.orange, 0), linewidth=1)
plot(ema200, "EMA200", color=color.new(color.purple, 0), linewidth=2)

plotshape(longLabelSignal, title="ENTRY LONG", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="ENTRY\nLONG")
plotshape(shortLabelSignal, title="ENTRY SHORT", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="ENTRY\nSHORT")

plotshape(showDebugDots and (longTrendOk or shortTrendOk), title="Debug trend ok", style=shape.circle, location=location.bottom, color=color.new(color.blue, 0), size=size.tiny, text="T")
plotshape(showDebugDots and (longPullbackZone or shortPullbackZone), title="Debug pullback ok", style=shape.circle, location=location.bottom, color=color.new(color.orange, 0), size=size.tiny, text="P")
plotshape(showDebugDots and (longTriggerOk or shortTriggerOk), title="Debug trigger ok", style=shape.circle, location=location.bottom, color=color.new(color.green, 0), size=size.tiny, text="C")
plotshape(showDebugDots and (longBlockedByCooldown or shortBlockedByCooldown), title="Debug cooldown block", style=shape.xcross, location=location.bottom, color=color.new(color.gray, 0), size=size.tiny, text="CD")
plotshape(showDebugDots and (lateLongState or lateShortState), title="Debug late block", style=shape.xcross, location=location.bottom, color=color.new(color.red, 0), size=size.tiny, text="L")

alertcondition(entryLong, title="ENTRY LONG", message="BTC Confluence Dashboard v1.1: ENTRY LONG")
alertcondition(entryShort, title="ENTRY SHORT", message="BTC Confluence Dashboard v1.1: ENTRY SHORT")
alertcondition(watchLong, title="WATCH LONG", message="BTC Confluence Dashboard v1.1: WATCH LONG")
alertcondition(watchShort, title="WATCH SHORT", message="BTC Confluence Dashboard v1.1: WATCH SHORT")
alertcondition(lateLongState, title="LATE LONG", message="BTC Confluence Dashboard v1.1: LATE LONG")
alertcondition(lateShortState, title="LATE SHORT", message="BTC Confluence Dashboard v1.1: LATE SHORT")

var table dashboard = table.new(position.top_right, 3, 12, border_width=1)

setRow(row, rowName, value, extra, bg) =>
    table.cell(dashboard, 0, row, rowName, text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(dashboard, 1, row, value, text_color=color.white, bgcolor=bg)
    table.cell(dashboard, 2, row, extra, text_color=color.white, bgcolor=color.new(color.black, 0))

if barstate.islast
    table.cell(dashboard, 0, 0, "BTC Dashboard v1.1", text_color=color.white, bgcolor=color.new(color.blue, 15))
    table.cell(dashboard, 1, 0, "Status", text_color=color.white, bgcolor=color.new(color.blue, 15))
    table.cell(dashboard, 2, 0, "Value", text_color=color.white, bgcolor=color.new(color.blue, 15))
    setRow(1, "HTF trend", htfText, htfTimeframe, htfColor)
    setRow(2, "EMA fan", emaFanText, emaSeparationText, emaFanColor)
    setRow(3, "EMA sep", emaSeparationValid ? "Valid" : "Weak", emaSeparationText, emaSeparationColor)
    setRow(4, "ATR regime", atrText, str.tostring(atrPercent, "#.##") + "%", atrColor)
    setRow(5, "Pullback", pullbackText, pullbackOk ? "Near EMA" : "-", pullbackColor)
    setRow(6, "Candle", candleText, str.tostring(bodySize, "#.##"), candleColor)
    setRow(7, "Long score", str.tostring(longScore), "/100", longScore >= minActionableLongScore ? color.new(color.green, 0) : color.new(color.gray, 25))
    setRow(8, "Short score", str.tostring(shortScore), "/100", shortScore >= minActionableShortScore ? color.new(color.red, 0) : color.new(color.gray, 25))
    setRow(9, "Final bias", biasText, "L " + str.tostring(longScore) + " / S " + str.tostring(shortScore), biasColor)
    setRow(10, "Action", actionState, "Dist " + str.tostring(priceDistanceFromEma20Atr, "#.##") + " ATR", actionColor)
    setRow(11, "Last signal", lastSignalText, "CD " + str.tostring(signalCooldownBars), color.new(color.gray, 25))
