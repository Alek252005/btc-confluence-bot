//@version=6
strategy("Clean Pullback v2.1 Dashboard Runner Exit", overlay=true, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=false, initial_capital=1000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.04, slippage=1, margin_long=100, margin_short=100)

directionMode = input.string("Both", "Direction mode", options=["Both", "Long only", "Short only"])
htfTimeframe = input.timeframe("60", "HTF timeframe")
emaFastLength = input.int(20, "EMA fast length", minval=1)
emaSlowLength = input.int(50, "EMA slow length", minval=1)
emaMacroLength = input.int(200, "EMA macro length", minval=1)
atrLength = input.int(14, "ATR length", minval=1)
atrStopMultiplier = input.float(1.5, "ATR stop multiplier", minval=0.1, step=0.1)
useAtrStopBuffer = input.bool(true, "Use ATR stop buffer")
atrStopBufferMultiplier = input.float(0.17, "ATR stop buffer multiplier", minval=0.0, step=0.1)
riskReward = input.float(2.0, "Risk reward", minval=0.1, step=0.1)
pullbackDistanceAtrMultiplier = input.float(0.8, "Pullback distance ATR multiplier", minval=0.0, step=0.1)
useEma200Filter = input.bool(true, "Use EMA200 filter")
useHtfTrendFilter = input.bool(true, "Use HTF trend filter")

useDynamicRiskSizing = input.bool(true, "Use dynamic risk sizing")
baseRiskPercent = input.float(0.75, "Base risk %", minval=0.01, step=0.1)
minRiskPercent = input.float(0.25, "Min risk %", minval=0.01, step=0.05)
maxRiskPercent = input.float(1.0, "Max risk %", minval=0.01, step=0.1)
maxPositionUsdt = input.float(300.0, "Max position USDT", minval=0.0, step=10.0)
minPositionUsdt = input.float(20.0, "Min position USDT", minval=0.0, step=5.0)
maxStopDistancePercent = input.float(3.0, "Max stop distance %", minval=0.1, step=0.1)
minRewardRisk = input.float(1.5, "Min reward risk", minval=0.1, step=0.1)
stopMethod = input.string("Wider of both", "Stop method", options=["Recent swing", "EMA50 ATR", "Wider of both"])
recentStopBars = input.int(5, "Recent bars for stop", minval=1)
useBreakEven = input.bool(false, "Use break even")
breakEvenAfterR = input.float(1.0, "Break even after R", minval=0.1, step=0.1)
useTrailingStop = input.bool(false, "Use trailing stop")
trailingAtrMultiplier = input.float(1.5, "Trailing ATR multiplier", minval=0.1, step=0.1)
useDailyLossProtection = input.bool(true, "Use daily loss protection")
maxDailyLossPercent = input.float(3.0, "Max daily loss %", minval=0.1, step=0.1)

useDashboardConfirmationFilter = input.bool(true, "Use dashboard confirmation filter", group="Dashboard confirmation filter")
dashboardFilterMode = input.string("Soft", "Dashboard filter mode", options=["Off", "Soft", "Strict"], group="Dashboard confirmation filter")
minDashboardLongScore = input.int(60, "Min dashboard long score", minval=0, maxval=100, group="Dashboard confirmation filter")
minDashboardShortScore = input.int(60, "Min dashboard short score", minval=0, maxval=100, group="Dashboard confirmation filter")
allowWatchSignals = input.bool(true, "Allow WATCH signals", group="Dashboard confirmation filter")
allowReadySignals = input.bool(true, "Allow READY signals", group="Dashboard confirmation filter")
allowEntrySignals = input.bool(true, "Allow ENTRY signals", group="Dashboard confirmation filter")
blockOppositeDashboardBias = input.bool(true, "Block opposite dashboard bias", group="Dashboard confirmation filter")
blockNeutralDashboardBias = input.bool(false, "Block neutral dashboard bias", group="Dashboard confirmation filter")
dashboardSignalCooldownBars = input.int(12, "Dashboard signal cooldown bars", minval=1, group="Dashboard confirmation filter")

useRunnerExit = input.bool(true, "Use runner exit", group="Runner exit")
partialTakeProfitR = input.float(1.5, "Partial take profit R", minval=0.1, step=0.1, group="Runner exit")
partialClosePercent = input.float(50.0, "Partial close %", minval=1.0, maxval=99.0, step=1.0, group="Runner exit")
runnerTrailingMode = input.string("EMA20 ATR", "Runner trailing mode", options=["EMA20 ATR", "Recent swing ATR", "ATR trail"], group="Runner exit")
runnerEmaAtrBuffer = input.float(0.5, "Runner EMA ATR buffer", minval=0.0, step=0.1, group="Runner exit")
runnerSwingBars = input.int(5, "Runner swing bars", minval=1, group="Runner exit")
runnerAtrMultiplier = input.float(1.5, "Runner ATR multiplier", minval=0.1, step=0.1, group="Runner exit")
moveStopToBreakevenAfterPartialTp = input.bool(true, "Move stop to breakeven after partial TP", group="Runner exit")
breakevenBufferAtr = input.float(0.05, "Breakeven buffer ATR", minval=0.0, step=0.01, group="Runner exit")
useFixedFinalTpForRunner = input.bool(false, "Use fixed final TP for runner", group="Runner exit")
runnerFinalTpR = input.float(4.0, "Runner final TP R", minval=0.1, step=0.1, group="Runner exit")

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)
emaMacro = ta.ema(close, emaMacroLength)
atr = ta.atr(atrLength)
dashboardEma20 = ta.ema(close, 20)
dashboardEma50 = ta.ema(close, 50)
dashboardEma200 = ta.ema(close, 200)

// HTF values use the previous completed HTF candle and lookahead_off, so this
// lower-timeframe strategy never sees unfinished higher-timeframe data.
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaFast = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaFastLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaSlowLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dashboardHtfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dashboardHtfEma20 = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 20)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dashboardHtfEma50 = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, 50)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBullish = htfClose > htfEmaFast and htfEmaFast > htfEmaSlow
htfBearish = htfClose < htfEmaFast and htfEmaFast < htfEmaSlow
dashboardHtfBullish = dashboardHtfClose > dashboardHtfEma20 and dashboardHtfEma20 > dashboardHtfEma50
dashboardHtfBearish = dashboardHtfClose < dashboardHtfEma20 and dashboardHtfEma20 < dashboardHtfEma50

pullbackDist = atr * pullbackDistanceAtrMultiplier
nearEmaFast = math.abs(close - emaFast) <= pullbackDist
nearEmaSlow = math.abs(close - emaSlow) <= pullbackDist
pullbackOk = nearEmaFast or nearEmaSlow
dashboardNearEma20 = math.abs(close - dashboardEma20) <= pullbackDist
dashboardNearEma50 = math.abs(close - dashboardEma50) <= pullbackDist
dashboardPullbackOk = dashboardNearEma20 or dashboardNearEma50
dashboardLongPullbackZone = dashboardPullbackOk and (dashboardEma20 > dashboardEma50 or dashboardHtfBullish)
dashboardShortPullbackZone = dashboardPullbackOk and (dashboardEma20 < dashboardEma50 or dashboardHtfBearish)
dashboardBullishFan = dashboardEma20 > dashboardEma50 and dashboardEma50 > dashboardEma200
dashboardBearishFan = dashboardEma20 < dashboardEma50 and dashboardEma50 < dashboardEma200
dashboardEmaSeparationAtr = atr > 0 ? math.abs(dashboardEma20 - dashboardEma50) / atr : na
dashboardEmaSeparationValid = dashboardEmaSeparationAtr >= 0.15
dashboardAtrPercent = close > 0 ? atr / close * 100.0 : na
dashboardAtrVolatilityNormal = dashboardAtrPercent >= 0.05 and dashboardAtrPercent <= 1.5
dashboardBodySize = math.abs(close - open)
dashboardAvgBody10 = ta.sma(dashboardBodySize, 10)
dashboardStrongBullish = close > open and dashboardBodySize > dashboardAvgBody10 * 1.2
dashboardStrongBearish = close < open and dashboardBodySize > dashboardAvgBody10 * 1.2

dashboardLongScore = (
     (dashboardHtfBullish ? 25 : 0) +
     (dashboardBullishFan ? 20 : 0) +
     (dashboardLongPullbackZone ? 20 : 0) +
     (dashboardStrongBullish ? 15 : 0) +
     (dashboardAtrVolatilityNormal ? 10 : 0) +
     (dashboardEmaSeparationValid ? 10 : 0)
)

dashboardShortScore = (
     (dashboardHtfBearish ? 25 : 0) +
     (dashboardBearishFan ? 20 : 0) +
     (dashboardShortPullbackZone ? 20 : 0) +
     (dashboardStrongBearish ? 15 : 0) +
     (dashboardAtrVolatilityNormal ? 10 : 0) +
     (dashboardEmaSeparationValid ? 10 : 0)
)

dashboardBiasLong = dashboardLongScore >= 70 and dashboardLongScore > dashboardShortScore
dashboardBiasShort = dashboardShortScore >= 70 and dashboardShortScore > dashboardLongScore
dashboardBiasText = dashboardBiasLong ? "LONG" : dashboardBiasShort ? "SHORT" : "WAIT"
dashboardLongTrendOk = dashboardHtfBullish and dashboardBullishFan and dashboardEmaSeparationValid and dashboardAtrVolatilityNormal
dashboardShortTrendOk = dashboardHtfBearish and dashboardBearishFan and dashboardEmaSeparationValid and dashboardAtrVolatilityNormal
dashboardWatchLong = dashboardLongTrendOk and not dashboardLongPullbackZone
dashboardWatchShort = dashboardShortTrendOk and not dashboardShortPullbackZone
dashboardReadyLong = dashboardLongTrendOk and dashboardLongPullbackZone and not dashboardStrongBullish
dashboardReadyShort = dashboardShortTrendOk and dashboardShortPullbackZone and not dashboardStrongBearish
dashboardEntryLong = dashboardLongTrendOk and dashboardLongPullbackZone and dashboardStrongBullish
dashboardEntryShort = dashboardShortTrendOk and dashboardShortPullbackZone and dashboardStrongBearish
dashboardActionText = dashboardEntryLong ? "ENTRY LONG" : dashboardEntryShort ? "ENTRY SHORT" : dashboardReadyLong ? "READY LONG" : dashboardReadyShort ? "READY SHORT" : dashboardWatchLong ? "WATCH LONG" : dashboardWatchShort ? "WATCH SHORT" : "WAIT"
dashboardActionColor = dashboardEntryLong or dashboardReadyLong ? color.new(color.green, 0) : dashboardEntryShort or dashboardReadyShort ? color.new(color.red, 0) : dashboardWatchLong or dashboardWatchShort ? color.new(color.yellow, 10) : color.new(color.gray, 25)

canLong = directionMode == "Both" or directionMode == "Long only"
canShort = directionMode == "Both" or directionMode == "Short only"
htfLongOk = not useHtfTrendFilter or htfBullish
htfShortOk = not useHtfTrendFilter or htfBearish
localTrendLongOk = emaFast > emaSlow or close > emaMacro
localTrendShortOk = emaFast < emaSlow or close < emaMacro
macroLongOk = not useEma200Filter or close > emaMacro
macroShortOk = not useEma200Filter or close < emaMacro
bullishConfirmation = close > open
bearishConfirmation = close < open

recentLow = ta.lowest(low, recentStopBars)
recentHigh = ta.highest(high, recentStopBars)

longRecentStop = recentLow - atr * atrStopMultiplier
longEmaStop = emaSlow - atr * atrStopMultiplier
originalLongStopPlan = switch stopMethod
    "Recent swing" => longRecentStop
    "EMA50 ATR" => longEmaStop
    => math.min(longRecentStop, longEmaStop)

shortRecentStop = recentHigh + atr * atrStopMultiplier
shortEmaStop = emaSlow + atr * atrStopMultiplier
originalShortStopPlan = switch stopMethod
    "Recent swing" => shortRecentStop
    "EMA50 ATR" => shortEmaStop
    => math.max(shortRecentStop, shortEmaStop)

longStopPlan = useAtrStopBuffer ? originalLongStopPlan - atr * atrStopBufferMultiplier : originalLongStopPlan
shortStopPlan = useAtrStopBuffer ? originalShortStopPlan + atr * atrStopBufferMultiplier : originalShortStopPlan

longEntryPlan = close
shortEntryPlan = close
longStopDistance = longEntryPlan - longStopPlan
shortStopDistance = shortStopPlan - shortEntryPlan
longStopDistancePercent = longStopDistance > 0 ? longStopDistance / longEntryPlan * 100.0 : na
shortStopDistancePercent = shortStopDistance > 0 ? shortStopDistance / shortEntryPlan * 100.0 : na
rewardRiskOk = riskReward >= minRewardRisk
longStopOk = longStopDistance > syminfo.mintick and longStopDistancePercent <= maxStopDistancePercent
shortStopOk = shortStopDistance > syminfo.mintick and shortStopDistancePercent <= maxStopDistancePercent

longQualityPoints = (
     (htfBullish ? 1 : 0) +
     (emaFast > emaSlow ? 1 : 0) +
     (close > emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bullishConfirmation ? 1 : 0) +
     (close > emaFast ? 1 : 0) +
     (longStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0)
)

shortQualityPoints = (
     (htfBearish ? 1 : 0) +
     (emaFast < emaSlow ? 1 : 0) +
     (close < emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bearishConfirmation ? 1 : 0) +
     (close < emaFast ? 1 : 0) +
     (shortStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0)
)

riskPercentFromQuality(points) =>
    points >= 6 ? maxRiskPercent : points >= 4 ? baseRiskPercent : points >= 3 ? minRiskPercent : na

longDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(longQualityPoints) : baseRiskPercent
shortDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(shortQualityPoints) : baseRiskPercent

longRiskCash = strategy.equity * longDynamicRiskPercent / 100.0
shortRiskCash = strategy.equity * shortDynamicRiskPercent / 100.0
longRiskQty = longStopDistance > syminfo.mintick ? longRiskCash / longStopDistance : na
shortRiskQty = shortStopDistance > syminfo.mintick ? shortRiskCash / shortStopDistance : na
longMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / longEntryPlan : longRiskQty
shortMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / shortEntryPlan : shortRiskQty
longQty = not na(longRiskQty) and not na(longMaxQty) ? math.min(longRiskQty, longMaxQty) : na
shortQty = not na(shortRiskQty) and not na(shortMaxQty) ? math.min(shortRiskQty, shortMaxQty) : na
longPositionUsdt = longQty * longEntryPlan
shortPositionUsdt = shortQty * shortEntryPlan

newDay = ta.change(time("D")) != 0
var float dayStartEquity = na
if na(dayStartEquity) or newDay
    dayStartEquity := strategy.equity

dailyLossPercent = dayStartEquity > 0 ? math.max((dayStartEquity - strategy.equity) / dayStartEquity * 100.0, 0.0) : 0.0
dailyLossOk = not useDailyLossProtection or dailyLossPercent < maxDailyLossPercent

baseLongSetup = barstate.isconfirmed and canLong and strategy.position_size == 0 and htfLongOk and localTrendLongOk and macroLongOk and pullbackOk and bullishConfirmation
baseShortSetup = barstate.isconfirmed and canShort and strategy.position_size == 0 and htfShortOk and localTrendShortOk and macroShortOk and pullbackOk and bearishConfirmation

longTradeOk = baseLongSetup and dailyLossOk and longQualityPoints >= 3 and not na(longDynamicRiskPercent) and longStopOk and rewardRiskOk and not na(longQty) and longQty > 0 and longPositionUsdt >= minPositionUsdt
shortTradeOk = baseShortSetup and dailyLossOk and shortQualityPoints >= 3 and not na(shortDynamicRiskPercent) and shortStopOk and rewardRiskOk and not na(shortQty) and shortQty > 0 and shortPositionUsdt >= minPositionUsdt

longSignalRaw = longTradeOk and not shortTradeOk
shortSignalRaw = shortTradeOk and not longTradeOk
dashboardLongScoreOk = dashboardLongScore >= minDashboardLongScore
dashboardShortScoreOk = dashboardShortScore >= minDashboardShortScore
dashboardLongActionAllowed = (
     (allowWatchSignals and dashboardWatchLong) or
     (allowReadySignals and dashboardReadyLong) or
     (allowEntrySignals and dashboardEntryLong)
)
dashboardShortActionAllowed = (
     (allowWatchSignals and dashboardWatchShort) or
     (allowReadySignals and dashboardReadyShort) or
     (allowEntrySignals and dashboardEntryShort)
)
dashboardLongSoftOk = (
     dashboardLongScoreOk and
     dashboardLongActionAllowed and
     (not blockOppositeDashboardBias or not dashboardBiasShort) and
     (not blockNeutralDashboardBias or dashboardBiasLong)
)
dashboardShortSoftOk = (
     dashboardShortScoreOk and
     dashboardShortActionAllowed and
     (not blockOppositeDashboardBias or not dashboardBiasLong) and
     (not blockNeutralDashboardBias or dashboardBiasShort)
)
dashboardLongStrictOk = dashboardBiasLong and dashboardLongScoreOk and (dashboardReadyLong or dashboardEntryLong)
dashboardShortStrictOk = dashboardBiasShort and dashboardShortScoreOk and (dashboardReadyShort or dashboardEntryShort)
dashboardLongFilterOk = (
     not useDashboardConfirmationFilter or
     dashboardFilterMode == "Off" or
     (dashboardFilterMode == "Soft" and dashboardLongSoftOk) or
     (dashboardFilterMode == "Strict" and dashboardLongStrictOk)
)
dashboardShortFilterOk = (
     not useDashboardConfirmationFilter or
     dashboardFilterMode == "Off" or
     (dashboardFilterMode == "Soft" and dashboardShortSoftOk) or
     (dashboardFilterMode == "Strict" and dashboardShortStrictOk)
)
var int lastDashboardLongSignalBar = na
var int lastDashboardShortSignalBar = na
dashboardLongCooldownOk = na(lastDashboardLongSignalBar) or bar_index - lastDashboardLongSignalBar >= dashboardSignalCooldownBars
dashboardShortCooldownOk = na(lastDashboardShortSignalBar) or bar_index - lastDashboardShortSignalBar >= dashboardSignalCooldownBars
longSignal = longSignalRaw and dashboardLongFilterOk and dashboardLongCooldownOk
shortSignal = shortSignalRaw and dashboardShortFilterOk and dashboardShortCooldownOk

if longSignal
    lastDashboardLongSignalBar := bar_index

if shortSignal
    lastDashboardShortSignalBar := bar_index

var float activeLongStop = na
var float activeLongTarget = na
var float activeLongPartialTarget = na
var float activeLongRunnerStop = na
var float activeLongInitialRisk = na
var bool activeLongPartialHit = false
var bool activeLongRunnerLabelShown = false
var bool activeLongPartialLabelShown = false
var float activeShortStop = na
var float activeShortTarget = na
var float activeShortPartialTarget = na
var float activeShortRunnerStop = na
var float activeShortInitialRisk = na
var bool activeShortPartialHit = false
var bool activeShortRunnerLabelShown = false
var bool activeShortPartialLabelShown = false

if strategy.position_size == 0
    activeLongStop := na
    activeLongTarget := na
    activeLongPartialTarget := na
    activeLongRunnerStop := na
    activeLongInitialRisk := na
    activeLongPartialHit := false
    activeLongRunnerLabelShown := false
    activeLongPartialLabelShown := false
    activeShortStop := na
    activeShortTarget := na
    activeShortPartialTarget := na
    activeShortRunnerStop := na
    activeShortInitialRisk := na
    activeShortPartialHit := false
    activeShortRunnerLabelShown := false
    activeShortPartialLabelShown := false

if longSignal
    activeLongStop := longStopPlan
    activeLongInitialRisk := longStopDistance
    activeLongTarget := longEntryPlan + longStopDistance * riskReward
    activeLongPartialTarget := longEntryPlan + longStopDistance * partialTakeProfitR
    activeLongRunnerStop := activeLongStop
    strategy.entry("Long", strategy.long, qty=longQty)
    if useRunnerExit
        strategy.exit("Long partial", from_entry="Long", stop=activeLongStop, limit=activeLongPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Long runner", from_entry="Long", stop=activeLongRunnerStop, limit=useFixedFinalTpForRunner ? longEntryPlan + longStopDistance * runnerFinalTpR : na, qty_percent=100.0 - partialClosePercent)
    else
        strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)
    label.new(bar_index, low, "Q " + str.tostring(longQualityPoints) + "\nRisk " + str.tostring(longDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(longPositionUsdt, "#.##") + "\nStop " + str.tostring(longStopDistancePercent, "#.##") + "%\nRisk $" + str.tostring(longRiskCash, "#.##"), style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if shortSignal
    activeShortStop := shortStopPlan
    activeShortInitialRisk := shortStopDistance
    activeShortTarget := shortEntryPlan - shortStopDistance * riskReward
    activeShortPartialTarget := shortEntryPlan - shortStopDistance * partialTakeProfitR
    activeShortRunnerStop := activeShortStop
    strategy.entry("Short", strategy.short, qty=shortQty)
    if useRunnerExit
        strategy.exit("Short partial", from_entry="Short", stop=activeShortStop, limit=activeShortPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Short runner", from_entry="Short", stop=activeShortRunnerStop, limit=useFixedFinalTpForRunner ? shortEntryPlan - shortStopDistance * runnerFinalTpR : na, qty_percent=100.0 - partialClosePercent)
    else
        strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)
    label.new(bar_index, high, "Q " + str.tostring(shortQualityPoints) + "\nRisk " + str.tostring(shortDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(shortPositionUsdt, "#.##") + "\nStop " + str.tostring(shortStopDistancePercent, "#.##") + "%\nRisk $" + str.tostring(shortRiskCash, "#.##"), style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

runnerRecentLow = ta.lowest(low, runnerSwingBars)
runnerRecentHigh = ta.highest(high, runnerSwingBars)

if strategy.position_size > 0 and not na(activeLongStop) and not na(activeLongTarget) and not na(activeLongInitialRisk)
    if useRunnerExit
        if not activeLongPartialHit and high >= activeLongPartialTarget
            activeLongPartialHit := true
            if not activeLongPartialLabelShown
                label.new(bar_index, high, "Partial TP", style=label.style_label_down, color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
                activeLongPartialLabelShown := true

        if activeLongPartialHit
            if moveStopToBreakevenAfterPartialTp
                activeLongRunnerStop := math.max(activeLongRunnerStop, strategy.position_avg_price + atr * breakevenBufferAtr)

            longTrailCandidate = switch runnerTrailingMode
                "EMA20 ATR" => emaFast - atr * runnerEmaAtrBuffer
                "Recent swing ATR" => runnerRecentLow - atr * atrStopBufferMultiplier
                => close - atr * runnerAtrMultiplier

            activeLongRunnerStop := math.max(activeLongRunnerStop, longTrailCandidate)

            if not activeLongRunnerLabelShown
                label.new(bar_index, low, "Runner active", style=label.style_label_up, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
                activeLongRunnerLabelShown := true

        strategy.exit("Long partial", from_entry="Long", stop=activeLongStop, limit=activeLongPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Long runner", from_entry="Long", stop=activeLongRunnerStop, limit=useFixedFinalTpForRunner ? strategy.position_avg_price + activeLongInitialRisk * runnerFinalTpR : na, qty_percent=100.0 - partialClosePercent)
    else
        if useBreakEven and high >= strategy.position_avg_price + activeLongInitialRisk * breakEvenAfterR
            activeLongStop := math.max(activeLongStop, strategy.position_avg_price)
        if useTrailingStop
            activeLongStop := math.max(activeLongStop, close - atr * trailingAtrMultiplier)
        strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if strategy.position_size < 0 and not na(activeShortStop) and not na(activeShortTarget) and not na(activeShortInitialRisk)
    if useRunnerExit
        if not activeShortPartialHit and low <= activeShortPartialTarget
            activeShortPartialHit := true
            if not activeShortPartialLabelShown
                label.new(bar_index, low, "Partial TP", style=label.style_label_up, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
                activeShortPartialLabelShown := true

        if activeShortPartialHit
            if moveStopToBreakevenAfterPartialTp
                activeShortRunnerStop := math.min(activeShortRunnerStop, strategy.position_avg_price - atr * breakevenBufferAtr)

            shortTrailCandidate = switch runnerTrailingMode
                "EMA20 ATR" => emaFast + atr * runnerEmaAtrBuffer
                "Recent swing ATR" => runnerRecentHigh + atr * atrStopBufferMultiplier
                => close + atr * runnerAtrMultiplier

            activeShortRunnerStop := math.min(activeShortRunnerStop, shortTrailCandidate)

            if not activeShortRunnerLabelShown
                label.new(bar_index, high, "Runner active", style=label.style_label_down, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
                activeShortRunnerLabelShown := true

        strategy.exit("Short partial", from_entry="Short", stop=activeShortStop, limit=activeShortPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Short runner", from_entry="Short", stop=activeShortRunnerStop, limit=useFixedFinalTpForRunner ? strategy.position_avg_price - activeShortInitialRisk * runnerFinalTpR : na, qty_percent=100.0 - partialClosePercent)
    else
        if useBreakEven and low <= strategy.position_avg_price - activeShortInitialRisk * breakEvenAfterR
            activeShortStop := math.min(activeShortStop, strategy.position_avg_price)
        if useTrailingStop
            activeShortStop := math.min(activeShortStop, close + atr * trailingAtrMultiplier)
        strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

plot(emaFast, "EMA fast", color=color.new(color.teal, 0), linewidth=1)
plot(emaSlow, "EMA slow", color=color.new(color.orange, 0), linewidth=1)
plot(emaMacro, "EMA macro", color=color.new(color.purple, 0), linewidth=2)

plotshape(longSignal, title="Long signal", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="LONG")
plotshape(shortSignal, title="Short signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="SHORT")

plot(strategy.position_size > 0 ? activeLongStop : na, "Long stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 ? activeLongTarget : na, "Long take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 and useRunnerExit ? activeLongPartialTarget : na, "Long partial take profit", color=color.new(color.green, 45), style=plot.style_linebr)
plot(strategy.position_size > 0 and useRunnerExit ? activeLongRunnerStop : na, "Long runner trailing stop", color=color.new(color.blue, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortStop : na, "Short stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortTarget : na, "Short take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 and useRunnerExit ? activeShortPartialTarget : na, "Short partial take profit", color=color.new(color.green, 45), style=plot.style_linebr)
plot(strategy.position_size < 0 and useRunnerExit ? activeShortRunnerStop : na, "Short runner trailing stop", color=color.new(color.blue, 0), style=plot.style_linebr)

dashboardHtfText = dashboardHtfBullish ? "Bullish" : dashboardHtfBearish ? "Bearish" : "Neutral"
dashboardEmaFanText = dashboardBullishFan ? "Bullish clean" : dashboardBearishFan ? "Bearish clean" : "Choppy"
dashboardAtrText = dashboardAtrVolatilityNormal ? "Normal" : dashboardAtrPercent < 0.05 ? "Low" : "High"
dashboardTableBiasColor = dashboardBiasLong ? color.new(color.green, 0) : dashboardBiasShort ? color.new(color.red, 0) : color.new(color.yellow, 10)

var table dashboardTable = table.new(position.top_right, 3, 9, border_width=1)

setDashboardRow(row, rowName, value, extra, bg) =>
    table.cell(dashboardTable, 0, row, rowName, text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(dashboardTable, 1, row, value, text_color=color.white, bgcolor=bg)
    table.cell(dashboardTable, 2, row, extra, text_color=color.white, bgcolor=color.new(color.black, 0))

if barstate.islast
    table.cell(dashboardTable, 0, 0, "Dashboard", text_color=color.white, bgcolor=color.new(color.blue, 15))
    table.cell(dashboardTable, 1, 0, "Status", text_color=color.white, bgcolor=color.new(color.blue, 15))
    table.cell(dashboardTable, 2, 0, "Value", text_color=color.white, bgcolor=color.new(color.blue, 15))
    setDashboardRow(1, "HTF trend", dashboardHtfText, htfTimeframe, dashboardHtfBullish ? color.new(color.green, 0) : dashboardHtfBearish ? color.new(color.red, 0) : color.new(color.gray, 25))
    setDashboardRow(2, "EMA fan", dashboardEmaFanText, "", dashboardBullishFan ? color.new(color.green, 0) : dashboardBearishFan ? color.new(color.red, 0) : color.new(color.yellow, 10))
    setDashboardRow(3, "ATR regime", dashboardAtrText, str.tostring(dashboardAtrPercent, "#.##") + "%", dashboardAtrVolatilityNormal ? color.new(color.green, 0) : color.new(color.yellow, 10))
    setDashboardRow(4, "Long score", str.tostring(dashboardLongScore), "/100", dashboardLongScore >= minDashboardLongScore ? color.new(color.green, 0) : color.new(color.gray, 25))
    setDashboardRow(5, "Short score", str.tostring(dashboardShortScore), "/100", dashboardShortScore >= minDashboardShortScore ? color.new(color.red, 0) : color.new(color.gray, 25))
    setDashboardRow(6, "Final bias", dashboardBiasText, "", dashboardTableBiasColor)
    setDashboardRow(7, "Action", dashboardActionText, "", dashboardActionColor)
    setDashboardRow(8, "Filter mode", dashboardFilterMode, useDashboardConfirmationFilter ? "ON" : "OFF", useDashboardConfirmationFilter ? color.new(color.green, 0) : color.new(color.gray, 25))
