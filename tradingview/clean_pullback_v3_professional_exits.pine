//@version=6
strategy("Clean Pullback v3 Professional Exits", overlay=true, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=false)

// Inputs
directionMode = input.string("Both", "Direction mode", options=["Both", "Long only", "Short only"])
htfTimeframe = input.timeframe("60", "HTF timeframe")
emaFastLength = input.int(20, "EMA fast length", minval=1)
emaSlowLength = input.int(50, "EMA slow length", minval=1)
emaMacroLength = input.int(200, "EMA macro length", minval=1)
atrLength = input.int(14, "ATR length", minval=1)
atrStopMultiplier = input.float(1.5, "ATR stop multiplier", minval=0.1, step=0.1)
emaStopBuffer = input.float(1.5, "EMA50 ATR stop buffer", minval=0.1, step=0.1)
riskReward = input.float(2.0, "Risk reward", minval=0.1, step=0.1)
pullbackDistanceAtrMultiplier = input.float(0.8, "Pullback distance ATR multiplier", minval=0.0, step=0.1)
useEma200Filter = input.bool(true, "Use EMA200 filter")
useHtfTrendFilter = input.bool(true, "Use HTF trend filter")

useDynamicRiskSizing = input.bool(true, "Use dynamic risk sizing")
baseRiskPercent = input.float(1.0, "Base risk %", minval=0.01, step=0.1)
minRiskPercent = input.float(0.25, "Min risk %", minval=0.01, step=0.05)
maxRiskPercent = input.float(1.5, "Max risk %", minval=0.01, step=0.1)
maxPositionUsdt = input.float(500.0, "Max position USDT", minval=0.0, step=10.0)
minPositionUsdt = input.float(20.0, "Min position USDT", minval=0.0, step=5.0)
maxStopDistancePercent = input.float(3.0, "Max stop distance %", minval=0.1, step=0.1)
minRewardRisk = input.float(1.5, "Min reward risk", minval=0.1, step=0.1)
stopMethod = input.string("Wider of both", "Stop method", options=["Swing ATR", "EMA50 ATR", "Wider of both", "Closer of both"])
recentStopBars = input.int(5, "Recent bars for stop", minval=1)

usePartialTakeProfit = input.bool(false, "Use partial take profit")
partialTakeProfitR = input.float(1.0, "Partial TP R", minval=0.1, step=0.1)
partialClosePercent = input.float(50.0, "Partial close %", minval=1.0, maxval=99.0, step=1.0)
useBreakEven = input.bool(false, "Use break even")
breakEvenAfterR = input.float(1.0, "Break even after R", minval=0.1, step=0.1)
useTrailingStop = input.bool(false, "Use trailing stop")
trailingAtrMultiplier = input.float(1.5, "Trailing ATR multiplier", minval=0.1, step=0.1)

useEmaFanFilter = input.bool(true, "Use EMA fan filter")
minEmaSeparationAtr = input.float(0.25, "Min EMA separation ATR", minval=0.0, step=0.05)
useDailyLossProtection = input.bool(true, "Use daily loss protection")
maxDailyLossPercent = input.float(3.0, "Max daily loss %", minval=0.1, step=0.1)

// Indicators
emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)
emaMacro = ta.ema(close, emaMacroLength)
atr = ta.atr(atrLength)

// Confirmed HTF values only: [1] is inside request.security and lookahead is off.
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaFast = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaFastLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaSlowLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBullish = htfClose > htfEmaFast and htfEmaFast > htfEmaSlow
htfBearish = htfClose < htfEmaFast and htfEmaFast < htfEmaSlow

pullbackDist = atr * pullbackDistanceAtrMultiplier
nearEmaFast = math.abs(close - emaFast) <= pullbackDist
nearEmaSlow = math.abs(close - emaSlow) <= pullbackDist
pullbackOk = nearEmaFast or nearEmaSlow

// Trend filters
canLong = directionMode == "Both" or directionMode == "Long only"
canShort = directionMode == "Both" or directionMode == "Short only"
htfLongOk = not useHtfTrendFilter or htfBullish
htfShortOk = not useHtfTrendFilter or htfBearish
emaSeparationOk = math.abs(emaFast - emaSlow) >= atr * minEmaSeparationAtr

emaFanLongOk = not useEmaFanFilter or (emaFast > emaSlow and (not useEma200Filter or emaSlow > emaMacro) and emaSeparationOk)
emaFanShortOk = not useEmaFanFilter or (emaFast < emaSlow and (not useEma200Filter or emaSlow < emaMacro) and emaSeparationOk)
localTrendLongOk = emaFanLongOk and (emaFast > emaSlow or close > emaMacro)
localTrendShortOk = emaFanShortOk and (emaFast < emaSlow or close < emaMacro)
macroLongOk = not useEma200Filter or close > emaMacro
macroShortOk = not useEma200Filter or close < emaMacro

bullishConfirmation = close > open
bearishConfirmation = close < open
rewardRiskOk = riskReward >= minRewardRisk

// Stop logic
recentLow = ta.lowest(low, recentStopBars)
recentHigh = ta.highest(high, recentStopBars)

longSwingStop = recentLow - atr * atrStopMultiplier
longEmaStop = emaSlow - atr * emaStopBuffer
longStopPlan = switch stopMethod
    "Swing ATR" => longSwingStop
    "EMA50 ATR" => longEmaStop
    "Closer of both" => math.max(longSwingStop, longEmaStop)
    => math.min(longSwingStop, longEmaStop)

shortSwingStop = recentHigh + atr * atrStopMultiplier
shortEmaStop = emaSlow + atr * emaStopBuffer
shortStopPlan = switch stopMethod
    "Swing ATR" => shortSwingStop
    "EMA50 ATR" => shortEmaStop
    "Closer of both" => math.min(shortSwingStop, shortEmaStop)
    => math.max(shortSwingStop, shortEmaStop)

longEntryPlan = close
shortEntryPlan = close
longStopDistance = longEntryPlan - longStopPlan
shortStopDistance = shortStopPlan - shortEntryPlan
longStopDistancePercent = longStopDistance > 0 ? longStopDistance / longEntryPlan * 100.0 : na
shortStopDistancePercent = shortStopDistance > 0 ? shortStopDistance / shortEntryPlan * 100.0 : na
longStopOk = longStopDistance > syminfo.mintick and longStopDistancePercent <= maxStopDistancePercent
shortStopOk = shortStopDistance > syminfo.mintick and shortStopDistancePercent <= maxStopDistancePercent

// Entry logic
baseLongSetup = barstate.isconfirmed and canLong and strategy.position_size == 0 and htfLongOk and localTrendLongOk and macroLongOk and pullbackOk and bullishConfirmation
baseShortSetup = barstate.isconfirmed and canShort and strategy.position_size == 0 and htfShortOk and localTrendShortOk and macroShortOk and pullbackOk and bearishConfirmation

longQualityPoints = (
     (htfBullish ? 1 : 0) +
     (emaFast > emaSlow ? 1 : 0) +
     (close > emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bullishConfirmation ? 1 : 0) +
     (close > emaFast ? 1 : 0) +
     (longStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0) +
     (emaSeparationOk ? 1 : 0)
)

shortQualityPoints = (
     (htfBearish ? 1 : 0) +
     (emaFast < emaSlow ? 1 : 0) +
     (close < emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bearishConfirmation ? 1 : 0) +
     (close < emaFast ? 1 : 0) +
     (shortStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0) +
     (emaSeparationOk ? 1 : 0)
)

riskPercentFromQuality(points) =>
    points >= 7 ? maxRiskPercent : points >= 5 ? baseRiskPercent : points >= 4 ? minRiskPercent : na

longDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(longQualityPoints) : baseRiskPercent
shortDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(shortQualityPoints) : baseRiskPercent

// Daily loss protection
newDay = ta.change(time("D")) != 0
var float dayStartEquity = na
if na(dayStartEquity) or newDay
    dayStartEquity := strategy.equity

dailyLossPercent = dayStartEquity > 0 ? math.max((dayStartEquity - strategy.equity) / dayStartEquity * 100.0, 0.0) : 0.0
dailyLossOk = not useDailyLossProtection or dailyLossPercent < maxDailyLossPercent

// Position sizing
longRiskCash = strategy.equity * longDynamicRiskPercent / 100.0
shortRiskCash = strategy.equity * shortDynamicRiskPercent / 100.0
longRiskQty = longStopDistance > syminfo.mintick ? longRiskCash / longStopDistance : na
shortRiskQty = shortStopDistance > syminfo.mintick ? shortRiskCash / shortStopDistance : na
longMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / longEntryPlan : longRiskQty
shortMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / shortEntryPlan : shortRiskQty
longQty = not na(longRiskQty) and not na(longMaxQty) ? math.min(longRiskQty, longMaxQty) : na
shortQty = not na(shortRiskQty) and not na(shortMaxQty) ? math.min(shortRiskQty, shortMaxQty) : na
longPositionUsdt = longQty * longEntryPlan
shortPositionUsdt = shortQty * shortEntryPlan

longTradeOk = baseLongSetup and dailyLossOk and longQualityPoints >= 4 and not na(longDynamicRiskPercent) and longStopOk and rewardRiskOk and not na(longQty) and longQty > 0 and longPositionUsdt >= minPositionUsdt
shortTradeOk = baseShortSetup and dailyLossOk and shortQualityPoints >= 4 and not na(shortDynamicRiskPercent) and shortStopOk and rewardRiskOk and not na(shortQty) and shortQty > 0 and shortPositionUsdt >= minPositionUsdt

longSignal = longTradeOk and not shortTradeOk
shortSignal = shortTradeOk and not longTradeOk

// Exit logic
var float activeLongStop = na
var float activeLongTarget = na
var float activeLongPartialTarget = na
var float activeLongInitialRisk = na
var float activeShortStop = na
var float activeShortTarget = na
var float activeShortPartialTarget = na
var float activeShortInitialRisk = na

if strategy.position_size == 0
    activeLongStop := na
    activeLongTarget := na
    activeLongPartialTarget := na
    activeLongInitialRisk := na
    activeShortStop := na
    activeShortTarget := na
    activeShortPartialTarget := na
    activeShortInitialRisk := na

if longSignal
    activeLongStop := longStopPlan
    activeLongInitialRisk := longStopDistance
    activeLongTarget := longEntryPlan + longStopDistance * riskReward
    activeLongPartialTarget := longEntryPlan + longStopDistance * partialTakeProfitR
    strategy.entry("Long", strategy.long, qty=longQty)
    label.new(bar_index, low, "Q " + str.tostring(longQualityPoints) + "\nRisk " + str.tostring(longDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(longPositionUsdt, "#.##") + "\nStop " + str.tostring(longStopDistancePercent, "#.##") + "%", style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if shortSignal
    activeShortStop := shortStopPlan
    activeShortInitialRisk := shortStopDistance
    activeShortTarget := shortEntryPlan - shortStopDistance * riskReward
    activeShortPartialTarget := shortEntryPlan - shortStopDistance * partialTakeProfitR
    strategy.entry("Short", strategy.short, qty=shortQty)
    label.new(bar_index, high, "Q " + str.tostring(shortQualityPoints) + "\nRisk " + str.tostring(shortDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(shortPositionUsdt, "#.##") + "\nStop " + str.tostring(shortStopDistancePercent, "#.##") + "%", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

if strategy.position_size > 0 and not na(activeLongStop) and not na(activeLongTarget) and not na(activeLongInitialRisk)
    if useBreakEven and high >= strategy.position_avg_price + activeLongInitialRisk * breakEvenAfterR
        activeLongStop := math.max(activeLongStop, strategy.position_avg_price)
    if useTrailingStop
        activeLongStop := math.max(activeLongStop, close - atr * trailingAtrMultiplier)
    if usePartialTakeProfit
        strategy.exit("Long partial", from_entry="Long", stop=activeLongStop, limit=activeLongPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Long final", from_entry="Long", stop=activeLongStop, limit=activeLongTarget, qty_percent=100.0 - partialClosePercent)
    else
        strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if strategy.position_size < 0 and not na(activeShortStop) and not na(activeShortTarget) and not na(activeShortInitialRisk)
    if useBreakEven and low <= strategy.position_avg_price - activeShortInitialRisk * breakEvenAfterR
        activeShortStop := math.min(activeShortStop, strategy.position_avg_price)
    if useTrailingStop
        activeShortStop := math.min(activeShortStop, close + atr * trailingAtrMultiplier)
    if usePartialTakeProfit
        strategy.exit("Short partial", from_entry="Short", stop=activeShortStop, limit=activeShortPartialTarget, qty_percent=partialClosePercent)
        strategy.exit("Short final", from_entry="Short", stop=activeShortStop, limit=activeShortTarget, qty_percent=100.0 - partialClosePercent)
    else
        strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

// Plots
plot(emaFast, "EMA20", color=color.new(color.teal, 0), linewidth=1)
plot(emaSlow, "EMA50", color=color.new(color.orange, 0), linewidth=1)
plot(emaMacro, "EMA200", color=color.new(color.purple, 0), linewidth=2)

plotshape(longSignal, title="Long signal", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="LONG")
plotshape(shortSignal, title="Short signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="SHORT")

plot(strategy.position_size > 0 ? activeLongStop : na, "Long stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 ? activeLongTarget : na, "Long take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 and usePartialTakeProfit ? activeLongPartialTarget : na, "Long partial take profit", color=color.new(color.green, 45), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortStop : na, "Short stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortTarget : na, "Short take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 and usePartialTakeProfit ? activeShortPartialTarget : na, "Short partial take profit", color=color.new(color.green, 45), style=plot.style_linebr)
