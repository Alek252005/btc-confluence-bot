//@version=6
strategy("Clean Pullback v1", overlay=true, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=false)

directionMode = input.string("Both", "Direction mode", options=["Both", "Long only", "Short only"])
htfTimeframe = input.timeframe("60", "HTF timeframe")
emaFastLength = input.int(20, "EMA fast length", minval=1)
emaSlowLength = input.int(50, "EMA slow length", minval=1)
emaMacroLength = input.int(200, "EMA macro length", minval=1)
atrLength = input.int(14, "ATR length", minval=1)
atrStopMultiplier = input.float(1.5, "ATR stop multiplier", minval=0.1, step=0.1)
riskReward = input.float(2.0, "Risk reward", minval=0.1, step=0.1)
pullbackDistanceAtrMultiplier = input.float(0.8, "Pullback distance ATR multiplier", minval=0.0, step=0.1)
useEma200Filter = input.bool(true, "Use EMA200 filter")
useHtfTrendFilter = input.bool(true, "Use HTF trend filter")

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)
emaMacro = ta.ema(close, emaMacroLength)
atr = ta.atr(atrLength)

// HTF values use the previous completed HTF candle and lookahead_off, so the
// lower timeframe never sees an unfinished higher-timeframe trend value.
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaFast = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaFastLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaSlowLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBullish = htfClose > htfEmaFast and htfEmaFast > htfEmaSlow
htfBearish = htfClose < htfEmaFast and htfEmaFast < htfEmaSlow

pullbackDist = atr * pullbackDistanceAtrMultiplier
nearEmaFast = math.abs(close - emaFast) <= pullbackDist
nearEmaSlow = math.abs(close - emaSlow) <= pullbackDist
pullbackOk = nearEmaFast or nearEmaSlow

canLong = directionMode == "Both" or directionMode == "Long only"
canShort = directionMode == "Both" or directionMode == "Short only"

htfLongOk = not useHtfTrendFilter or htfBullish
htfShortOk = not useHtfTrendFilter or htfBearish
localTrendLongOk = emaFast > emaSlow or close > emaMacro
localTrendShortOk = emaFast < emaSlow or close < emaMacro
macroLongOk = not useEma200Filter or close > emaMacro
macroShortOk = not useEma200Filter or close < emaMacro

bullishConfirmation = close > open
bearishConfirmation = close < open

longSetup = (
     barstate.isconfirmed and
     canLong and
     strategy.position_size == 0 and
     htfLongOk and
     localTrendLongOk and
     macroLongOk and
     pullbackOk and
     bullishConfirmation
)

shortSetup = (
     barstate.isconfirmed and
     canShort and
     strategy.position_size == 0 and
     htfShortOk and
     localTrendShortOk and
     macroShortOk and
     pullbackOk and
     bearishConfirmation
)

longSignal = longSetup and not shortSetup
shortSignal = shortSetup and not longSetup

var float activeLongStop = na
var float activeShortStop = na

recentLow5 = ta.lowest(low, 5)
recentHigh5 = ta.highest(high, 5)

if strategy.position_size == 0
    activeLongStop := na
    activeShortStop := na

if longSignal
    // Stop uses the recent 5-bar low minus an ATR buffer. This is simple,
    // reproducible, and only uses information available on the closed bar.
    candidateStop = recentLow5 - atr * atrStopMultiplier
    if candidateStop < close
        activeLongStop := candidateStop
        strategy.entry("Long", strategy.long)

if shortSignal
    // Stop uses the recent 5-bar high plus an ATR buffer. This mirrors the
    // long logic while avoiding future pivots or repainting structure labels.
    candidateStop = recentHigh5 + atr * atrStopMultiplier
    if candidateStop > close
        activeShortStop := candidateStop
        strategy.entry("Short", strategy.short)

float longTakeProfit = na
float shortTakeProfit = na

if strategy.position_size > 0 and not na(activeLongStop)
    longRisk = strategy.position_avg_price - activeLongStop
    if longRisk > syminfo.mintick
        longTakeProfit := strategy.position_avg_price + longRisk * riskReward
        strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=longTakeProfit)

if strategy.position_size < 0 and not na(activeShortStop)
    shortRisk = activeShortStop - strategy.position_avg_price
    if shortRisk > syminfo.mintick
        shortTakeProfit := strategy.position_avg_price - shortRisk * riskReward
        strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=shortTakeProfit)

plot(emaFast, "EMA fast", color=color.new(color.teal, 0), linewidth=1)
plot(emaSlow, "EMA slow", color=color.new(color.orange, 0), linewidth=1)
plot(emaMacro, "EMA macro", color=color.new(color.purple, 0), linewidth=2)

plotshape(longSignal, title="Long signal", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="LONG")
plotshape(shortSignal, title="Short signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="SHORT")

plot(strategy.position_size > 0 ? activeLongStop : na, "Long stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 ? longTakeProfit : na, "Long take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortStop : na, "Short stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? shortTakeProfit : na, "Short take profit", color=color.new(color.green, 0), style=plot.style_linebr)
