//@version=6
strategy("Clean Pullback v2.1 ATR Stop Buffer Fixed Defaults", overlay=true, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=false, initial_capital=1000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.04, slippage=1, margin_long=100, margin_short=100)

directionMode = input.string("Both", "Direction mode", options=["Both", "Long only", "Short only"])
htfTimeframe = input.timeframe("60", "HTF timeframe")
emaFastLength = input.int(20, "EMA fast length", minval=1)
emaSlowLength = input.int(50, "EMA slow length", minval=1)
emaMacroLength = input.int(200, "EMA macro length", minval=1)
atrLength = input.int(14, "ATR length", minval=1)
atrStopMultiplier = input.float(1.5, "ATR stop multiplier", minval=0.1, step=0.1)
useAtrStopBuffer = input.bool(true, "Use ATR stop buffer")
atrStopBufferMultiplier = input.float(0.17, "ATR stop buffer multiplier", minval=0.0, step=0.1)
riskReward = input.float(2.0, "Risk reward", minval=0.1, step=0.1)
pullbackDistanceAtrMultiplier = input.float(0.8, "Pullback distance ATR multiplier", minval=0.0, step=0.1)
useEma200Filter = input.bool(true, "Use EMA200 filter")
useHtfTrendFilter = input.bool(true, "Use HTF trend filter")

useDynamicRiskSizing = input.bool(true, "Use dynamic risk sizing")
baseRiskPercent = input.float(0.75, "Base risk %", minval=0.01, step=0.1)
minRiskPercent = input.float(0.25, "Min risk %", minval=0.01, step=0.05)
maxRiskPercent = input.float(1.0, "Max risk %", minval=0.01, step=0.1)
maxPositionUsdt = input.float(300.0, "Max position USDT", minval=0.0, step=10.0)
minPositionUsdt = input.float(20.0, "Min position USDT", minval=0.0, step=5.0)
maxStopDistancePercent = input.float(3.0, "Max stop distance %", minval=0.1, step=0.1)
minRewardRisk = input.float(1.5, "Min reward risk", minval=0.1, step=0.1)
stopMethod = input.string("Wider of both", "Stop method", options=["Recent swing", "EMA50 ATR", "Wider of both"])
recentStopBars = input.int(5, "Recent bars for stop", minval=1)
useBreakEven = input.bool(false, "Use break even")
breakEvenAfterR = input.float(1.0, "Break even after R", minval=0.1, step=0.1)
useTrailingStop = input.bool(false, "Use trailing stop")
trailingAtrMultiplier = input.float(1.5, "Trailing ATR multiplier", minval=0.1, step=0.1)
useDailyLossProtection = input.bool(true, "Use daily loss protection")
maxDailyLossPercent = input.float(3.0, "Max daily loss %", minval=0.1, step=0.1)
use4hRangeConfluenceFilter = input.bool(false, "Use 4H Range Confluence Filter")
range4hFilterMode = input.string("Off", "4H Range Filter Mode", options=["Off", "Soft", "Confirm", "Strict"])
range4hTimezone = input.string("America/New_York", "4H Range Timezone")
range4hStartHour = input.int(0, "4H Range Start Hour", minval=0, maxval=23)
range4hDurationHours = input.int(4, "4H Range Duration Hours", minval=1, maxval=12)
range4hConfluenceLookbackBars = input.int(48, "4H Confluence Lookback Bars", minval=1)
blockOpposite4hReclaim = input.bool(true, "Block opposite 4H reclaim")
requireSameDirectionReclaim = input.bool(true, "Require same-direction reclaim in Confirm/Strict")
show4hRangeBox = input.bool(true, "Show 4H range box")
show4hRangeLabels = input.bool(true, "Show 4H range labels")
show4hConfluenceDebugTable = input.bool(true, "Show 4H confluence debug table")
showBlocked4hConfluenceSignals = input.bool(true, "Show blocked 4H confluence signals")

emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)
emaMacro = ta.ema(close, emaMacroLength)
atr = ta.atr(atrLength)

// HTF values use the previous completed HTF candle and lookahead_off, so this
// lower-timeframe strategy never sees unfinished higher-timeframe data.
htfClose = request.security(syminfo.tickerid, htfTimeframe, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaFast = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaFastLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaSlowLength)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htfBullish = htfClose > htfEmaFast and htfEmaFast > htfEmaSlow
htfBearish = htfClose < htfEmaFast and htfEmaFast < htfEmaSlow

pullbackDist = atr * pullbackDistanceAtrMultiplier
nearEmaFast = math.abs(close - emaFast) <= pullbackDist
nearEmaSlow = math.abs(close - emaSlow) <= pullbackDist
pullbackOk = nearEmaFast or nearEmaSlow

canLong = directionMode == "Both" or directionMode == "Long only"
canShort = directionMode == "Both" or directionMode == "Short only"
htfLongOk = not useHtfTrendFilter or htfBullish
htfShortOk = not useHtfTrendFilter or htfBearish
localTrendLongOk = emaFast > emaSlow or close > emaMacro
localTrendShortOk = emaFast < emaSlow or close < emaMacro
macroLongOk = not useEma200Filter or close > emaMacro
macroShortOk = not useEma200Filter or close < emaMacro
bullishConfirmation = close > open
bearishConfirmation = close < open

recentLow = ta.lowest(low, recentStopBars)
recentHigh = ta.highest(high, recentStopBars)

longRecentStop = recentLow - atr * atrStopMultiplier
longEmaStop = emaSlow - atr * atrStopMultiplier
originalLongStopPlan = switch stopMethod
    "Recent swing" => longRecentStop
    "EMA50 ATR" => longEmaStop
    => math.min(longRecentStop, longEmaStop)

shortRecentStop = recentHigh + atr * atrStopMultiplier
shortEmaStop = emaSlow + atr * atrStopMultiplier
originalShortStopPlan = switch stopMethod
    "Recent swing" => shortRecentStop
    "EMA50 ATR" => shortEmaStop
    => math.max(shortRecentStop, shortEmaStop)

longStopPlan = useAtrStopBuffer ? originalLongStopPlan - atr * atrStopBufferMultiplier : originalLongStopPlan
shortStopPlan = useAtrStopBuffer ? originalShortStopPlan + atr * atrStopBufferMultiplier : originalShortStopPlan

longEntryPlan = close
shortEntryPlan = close
longStopDistance = longEntryPlan - longStopPlan
shortStopDistance = shortStopPlan - shortEntryPlan
longStopDistancePercent = longStopDistance > 0 ? longStopDistance / longEntryPlan * 100.0 : na
shortStopDistancePercent = shortStopDistance > 0 ? shortStopDistance / shortEntryPlan * 100.0 : na
rewardRiskOk = riskReward >= minRewardRisk
longStopOk = longStopDistance > syminfo.mintick and longStopDistancePercent <= maxStopDistancePercent
shortStopOk = shortStopDistance > syminfo.mintick and shortStopDistancePercent <= maxStopDistancePercent

longQualityPoints = (
     (htfBullish ? 1 : 0) +
     (emaFast > emaSlow ? 1 : 0) +
     (close > emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bullishConfirmation ? 1 : 0) +
     (close > emaFast ? 1 : 0) +
     (longStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0)
)

shortQualityPoints = (
     (htfBearish ? 1 : 0) +
     (emaFast < emaSlow ? 1 : 0) +
     (close < emaMacro ? 1 : 0) +
     (pullbackOk ? 1 : 0) +
     (bearishConfirmation ? 1 : 0) +
     (close < emaFast ? 1 : 0) +
     (shortStopOk ? 1 : 0) +
     (rewardRiskOk ? 1 : 0)
)

riskPercentFromQuality(points) =>
    points >= 6 ? maxRiskPercent : points >= 4 ? baseRiskPercent : points >= 3 ? minRiskPercent : na

longDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(longQualityPoints) : baseRiskPercent
shortDynamicRiskPercent = useDynamicRiskSizing ? riskPercentFromQuality(shortQualityPoints) : baseRiskPercent

longRiskCash = strategy.equity * longDynamicRiskPercent / 100.0
shortRiskCash = strategy.equity * shortDynamicRiskPercent / 100.0
longRiskQty = longStopDistance > syminfo.mintick ? longRiskCash / longStopDistance : na
shortRiskQty = shortStopDistance > syminfo.mintick ? shortRiskCash / shortStopDistance : na
longMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / longEntryPlan : longRiskQty
shortMaxQty = maxPositionUsdt > 0 ? maxPositionUsdt / shortEntryPlan : shortRiskQty
longQty = not na(longRiskQty) and not na(longMaxQty) ? math.min(longRiskQty, longMaxQty) : na
shortQty = not na(shortRiskQty) and not na(shortMaxQty) ? math.min(shortRiskQty, shortMaxQty) : na
longPositionUsdt = longQty * longEntryPlan
shortPositionUsdt = shortQty * shortEntryPlan

newDay = ta.change(time("D")) != 0
var float dayStartEquity = na
if na(dayStartEquity) or newDay
    dayStartEquity := strategy.equity

dailyLossPercent = dayStartEquity > 0 ? math.max((dayStartEquity - strategy.equity) / dayStartEquity * 100.0, 0.0) : 0.0
dailyLossOk = not useDailyLossProtection or dailyLossPercent < maxDailyLossPercent

baseLongSetup = barstate.isconfirmed and canLong and strategy.position_size == 0 and htfLongOk and localTrendLongOk and macroLongOk and pullbackOk and bullishConfirmation
baseShortSetup = barstate.isconfirmed and canShort and strategy.position_size == 0 and htfShortOk and localTrendShortOk and macroShortOk and pullbackOk and bearishConfirmation

longTradeOk = baseLongSetup and dailyLossOk and longQualityPoints >= 3 and not na(longDynamicRiskPercent) and longStopOk and rewardRiskOk and not na(longQty) and longQty > 0 and longPositionUsdt >= minPositionUsdt
shortTradeOk = baseShortSetup and dailyLossOk and shortQualityPoints >= 3 and not na(shortDynamicRiskPercent) and shortStopOk and rewardRiskOk and not na(shortQty) and shortQty > 0 and shortPositionUsdt >= minPositionUsdt

longSignalRaw = longTradeOk and not shortTradeOk
shortSignalRaw = shortTradeOk and not longTradeOk

use4hActive = use4hRangeConfluenceFilter and range4hFilterMode != "Off"

range4hHour = hour(time, range4hTimezone)
range4hMinute = minute(time, range4hTimezone)
range4hMinuteOfDay = range4hHour * 60 + range4hMinute
range4hDayKey = year(time, range4hTimezone) * 10000 + month(time, range4hTimezone) * 100 + dayofmonth(time, range4hTimezone)
range4hDayChange = ta.change(range4hDayKey)
range4hNewDay = not na(range4hDayChange) and range4hDayChange != 0
range4hStartMinute = range4hStartHour * 60
range4hEndMinuteRaw = range4hStartMinute + range4hDurationHours * 60
range4hEndMinute = range4hEndMinuteRaw % 1440
range4hWindow = range4hEndMinuteRaw <= 1440 ? range4hMinuteOfDay >= range4hStartMinute and range4hMinuteOfDay < range4hEndMinuteRaw : range4hMinuteOfDay >= range4hStartMinute or range4hMinuteOfDay < range4hEndMinute
range4hPriorWindow = range4hWindow[1] == true
range4hStarted = range4hWindow and (not range4hPriorWindow or range4hNewDay)
range4hEnded = not range4hWindow and range4hPriorWindow

var float range4hHigh = na
var float range4hLow = na
var int range4hStartBar = na
var int range4hEndBar = na
var bool range4hLocked = false
var bool range4hHighSweepActive = false
var bool range4hLowSweepActive = false
var string range4hLastSweep = "-"
var string range4hLastReclaim = "-"
var int range4hLastReclaimLongBar = na
var int range4hLastReclaimShortBar = na
var int range4hRawLongSignalCount = 0
var int range4hRawShortSignalCount = 0
var int range4hPassedLongSignalCount = 0
var int range4hPassedShortSignalCount = 0
var int range4hBlockedLongSignalCount = 0
var int range4hBlockedShortSignalCount = 0
var string range4hLastBlockReason = "-"
var line range4hHighLine = na
var line range4hLowLine = na
var box range4hBox = na

if use4hActive and range4hNewDay
    range4hHigh := na
    range4hLow := na
    range4hStartBar := na
    range4hEndBar := na
    range4hLocked := false
    range4hHighSweepActive := false
    range4hLowSweepActive := false
    range4hLastSweep := "-"
    range4hLastReclaim := "-"
    range4hLastReclaimLongBar := na
    range4hLastReclaimShortBar := na
    range4hRawLongSignalCount := 0
    range4hRawShortSignalCount := 0
    range4hPassedLongSignalCount := 0
    range4hPassedShortSignalCount := 0
    range4hBlockedLongSignalCount := 0
    range4hBlockedShortSignalCount := 0
    range4hLastBlockReason := "-"
    range4hHighLine := na
    range4hLowLine := na
    range4hBox := na

if use4hActive and range4hStarted
    range4hHigh := high
    range4hLow := low
    range4hStartBar := bar_index
    range4hEndBar := na
    range4hLocked := false
    range4hHighSweepActive := false
    range4hLowSweepActive := false
    range4hLastSweep := "-"
    range4hLastReclaim := "-"
    range4hLastReclaimLongBar := na
    range4hLastReclaimShortBar := na
    range4hRawLongSignalCount := 0
    range4hRawShortSignalCount := 0
    range4hPassedLongSignalCount := 0
    range4hPassedShortSignalCount := 0
    range4hBlockedLongSignalCount := 0
    range4hBlockedShortSignalCount := 0
    range4hLastBlockReason := "-"
    if show4hRangeBox
        range4hBox := box.new(range4hStartBar, range4hHigh, bar_index, range4hLow, bgcolor=color.new(color.blue, 90), border_color=color.new(color.blue, 45))

if use4hActive and range4hWindow and not na(range4hStartBar)
    range4hHigh := math.max(nz(range4hHigh, high), high)
    range4hLow := math.min(nz(range4hLow, low), low)
    if show4hRangeBox and not na(range4hBox)
        box.set_top(range4hBox, range4hHigh)
        box.set_bottom(range4hBox, range4hLow)
        box.set_right(range4hBox, bar_index)

if use4hActive and range4hEnded and not na(range4hHigh) and not na(range4hLow)
    range4hLocked := true
    range4hEndBar := bar_index - 1
    range4hHighLine := line.new(range4hEndBar, range4hHigh, bar_index, range4hHigh, color=color.new(color.red, 25), width=1)
    range4hLowLine := line.new(range4hEndBar, range4hLow, bar_index, range4hLow, color=color.new(color.green, 25), width=1)
    if show4hRangeLabels
        label.new(range4hEndBar, range4hHigh, "4H High", style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.tiny)
        label.new(range4hEndBar, range4hLow, "4H Low", style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.tiny)

if use4hActive and range4hLocked and not range4hNewDay
    if not na(range4hHighLine)
        line.set_x2(range4hHighLine, bar_index)
    if not na(range4hLowLine)
        line.set_x2(range4hLowLine, bar_index)
    if show4hRangeBox and not na(range4hBox)
        box.set_right(range4hBox, bar_index)

range4hInside = range4hLocked and close <= range4hHigh and close >= range4hLow
range4hSweepHighEvent = use4hActive and barstate.isconfirmed and range4hLocked and close > range4hHigh and close[1] <= range4hHigh
range4hSweepLowEvent = use4hActive and barstate.isconfirmed and range4hLocked and close < range4hLow and close[1] >= range4hLow

if range4hSweepHighEvent
    range4hHighSweepActive := true
    range4hLastSweep := "High"
    label.new(bar_index, high, "Sweep High", style=label.style_label_down, color=color.new(color.orange, 15), textcolor=color.white, size=size.tiny)

if range4hSweepLowEvent
    range4hLowSweepActive := true
    range4hLastSweep := "Low"
    label.new(bar_index, low, "Sweep Low", style=label.style_label_up, color=color.new(color.orange, 15), textcolor=color.white, size=size.tiny)

range4hReclaimShortEvent = use4hActive and barstate.isconfirmed and range4hHighSweepActive and range4hInside
range4hReclaimLongEvent = use4hActive and barstate.isconfirmed and range4hLowSweepActive and range4hInside

if range4hReclaimShortEvent
    range4hHighSweepActive := false
    range4hLastReclaim := "Short"
    range4hLastReclaimShortBar := bar_index
    label.new(bar_index, high, "Reclaim Short", style=label.style_label_down, color=color.new(color.red, 15), textcolor=color.white, size=size.tiny)

if range4hReclaimLongEvent
    range4hLowSweepActive := false
    range4hLastReclaim := "Long"
    range4hLastReclaimLongBar := bar_index
    label.new(bar_index, low, "Reclaim Long", style=label.style_label_up, color=color.new(color.green, 15), textcolor=color.white, size=size.tiny)

range4hWidthAtr = range4hLocked and atr > 0 ? (range4hHigh - range4hLow) / atr : na
range4hRecentReclaimLong = use4hActive and not na(range4hLastReclaimLongBar) and bar_index - range4hLastReclaimLongBar <= range4hConfluenceLookbackBars
range4hRecentReclaimShort = use4hActive and not na(range4hLastReclaimShortBar) and bar_index - range4hLastReclaimShortBar <= range4hConfluenceLookbackBars
range4hLongMoreRecent = range4hRecentReclaimLong and (not range4hRecentReclaimShort or range4hLastReclaimLongBar > range4hLastReclaimShortBar)
range4hShortMoreRecent = range4hRecentReclaimShort and (not range4hRecentReclaimLong or range4hLastReclaimShortBar > range4hLastReclaimLongBar)
range4hBias = range4hLongMoreRecent ? "LONG" : range4hShortMoreRecent ? "SHORT" : "WAIT"

range4hSoftLongOk = not blockOpposite4hReclaim or not range4hShortMoreRecent
range4hSoftShortOk = not blockOpposite4hReclaim or not range4hLongMoreRecent
range4hConfirmLongOk = (not requireSameDirectionReclaim or range4hRecentReclaimLong) and range4hSoftLongOk
range4hConfirmShortOk = (not requireSameDirectionReclaim or range4hRecentReclaimShort) and range4hSoftShortOk
range4hStrictLongOk = (not requireSameDirectionReclaim or range4hRecentReclaimLong) and (not blockOpposite4hReclaim or not range4hShortMoreRecent)
range4hStrictShortOk = (not requireSameDirectionReclaim or range4hRecentReclaimShort) and (not blockOpposite4hReclaim or not range4hLongMoreRecent)

range4hLongFilterOk = not use4hActive or (range4hFilterMode == "Soft" and range4hSoftLongOk) or (range4hFilterMode == "Confirm" and range4hConfirmLongOk) or (range4hFilterMode == "Strict" and range4hStrictLongOk)
range4hShortFilterOk = not use4hActive or (range4hFilterMode == "Soft" and range4hSoftShortOk) or (range4hFilterMode == "Confirm" and range4hConfirmShortOk) or (range4hFilterMode == "Strict" and range4hStrictShortOk)

longSignal = use4hActive ? longSignalRaw and range4hLongFilterOk : longSignalRaw
shortSignal = use4hActive ? shortSignalRaw and range4hShortFilterOk : shortSignalRaw
range4hBlockedLongSignal = use4hActive and longSignalRaw and not longSignal
range4hBlockedShortSignal = use4hActive and shortSignalRaw and not shortSignal
range4hLongBlockReason = range4hFilterMode == "Soft" and range4hBlockedLongSignal ? "Recent Reclaim Short" : range4hFilterMode == "Confirm" and range4hBlockedLongSignal ? (not range4hRecentReclaimLong ? "No recent Reclaim Long" : "Opposite reclaim") : range4hFilterMode == "Strict" and range4hBlockedLongSignal ? (not range4hRecentReclaimLong ? "No recent Reclaim Long" : "Short reclaim newer") : "-"
range4hShortBlockReason = range4hFilterMode == "Soft" and range4hBlockedShortSignal ? "Recent Reclaim Long" : range4hFilterMode == "Confirm" and range4hBlockedShortSignal ? (not range4hRecentReclaimShort ? "No recent Reclaim Short" : "Opposite reclaim") : range4hFilterMode == "Strict" and range4hBlockedShortSignal ? (not range4hRecentReclaimShort ? "No recent Reclaim Short" : "Long reclaim newer") : "-"

if use4hActive and longSignalRaw
    range4hRawLongSignalCount += 1
if use4hActive and shortSignalRaw
    range4hRawShortSignalCount += 1
if use4hActive and longSignal
    range4hPassedLongSignalCount += 1
if use4hActive and shortSignal
    range4hPassedShortSignalCount += 1
if range4hBlockedLongSignal
    range4hBlockedLongSignalCount += 1
    range4hLastBlockReason := "L: " + range4hLongBlockReason
if range4hBlockedShortSignal
    range4hBlockedShortSignalCount += 1
    range4hLastBlockReason := "S: " + range4hShortBlockReason

var float activeLongStop = na
var float activeLongTarget = na
var float activeLongInitialRisk = na
var float activeShortStop = na
var float activeShortTarget = na
var float activeShortInitialRisk = na

if strategy.position_size == 0
    activeLongStop := na
    activeLongTarget := na
    activeLongInitialRisk := na
    activeShortStop := na
    activeShortTarget := na
    activeShortInitialRisk := na

if longSignal
    activeLongStop := longStopPlan
    activeLongInitialRisk := longStopDistance
    activeLongTarget := longEntryPlan + longStopDistance * riskReward
    strategy.entry("Long", strategy.long, qty=longQty)
    strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)
    label.new(bar_index, low, "Q " + str.tostring(longQualityPoints) + "\nRisk " + str.tostring(longDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(longPositionUsdt, "#.##") + "\nStop " + str.tostring(longStopDistancePercent, "#.##") + "%\nRisk $" + str.tostring(longRiskCash, "#.##"), style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if shortSignal
    activeShortStop := shortStopPlan
    activeShortInitialRisk := shortStopDistance
    activeShortTarget := shortEntryPlan - shortStopDistance * riskReward
    strategy.entry("Short", strategy.short, qty=shortQty)
    strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)
    label.new(bar_index, high, "Q " + str.tostring(shortQualityPoints) + "\nRisk " + str.tostring(shortDynamicRiskPercent, "#.##") + "%\nUSDT " + str.tostring(shortPositionUsdt, "#.##") + "\nStop " + str.tostring(shortStopDistancePercent, "#.##") + "%\nRisk $" + str.tostring(shortRiskCash, "#.##"), style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

if strategy.position_size > 0 and not na(activeLongStop) and not na(activeLongTarget) and not na(activeLongInitialRisk)
    if useBreakEven and high >= strategy.position_avg_price + activeLongInitialRisk * breakEvenAfterR
        activeLongStop := math.max(activeLongStop, strategy.position_avg_price)
    if useTrailingStop
        activeLongStop := math.max(activeLongStop, close - atr * trailingAtrMultiplier)
    strategy.exit("Long exit", from_entry="Long", stop=activeLongStop, limit=activeLongTarget)

if strategy.position_size < 0 and not na(activeShortStop) and not na(activeShortTarget) and not na(activeShortInitialRisk)
    if useBreakEven and low <= strategy.position_avg_price - activeShortInitialRisk * breakEvenAfterR
        activeShortStop := math.min(activeShortStop, strategy.position_avg_price)
    if useTrailingStop
        activeShortStop := math.min(activeShortStop, close + atr * trailingAtrMultiplier)
    strategy.exit("Short exit", from_entry="Short", stop=activeShortStop, limit=activeShortTarget)

plot(emaFast, "EMA fast", color=color.new(color.teal, 0), linewidth=1)
plot(emaSlow, "EMA slow", color=color.new(color.orange, 0), linewidth=1)
plot(emaMacro, "EMA macro", color=color.new(color.purple, 0), linewidth=2)

plotshape(longSignal, title="Long signal", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="LONG")
plotshape(shortSignal, title="Short signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="SHORT")
plotshape(use4hActive and showBlocked4hConfluenceSignals and range4hBlockedLongSignal, title="Blocked long 4H", style=shape.xcross, location=location.belowbar, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny, text="BLOCK L 4H")
plotshape(use4hActive and showBlocked4hConfluenceSignals and range4hBlockedShortSignal, title="Blocked short 4H", style=shape.xcross, location=location.abovebar, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny, text="BLOCK S 4H")

plot(strategy.position_size > 0 ? activeLongStop : na, "Long stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size > 0 ? activeLongTarget : na, "Long take profit", color=color.new(color.green, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortStop : na, "Short stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(strategy.position_size < 0 ? activeShortTarget : na, "Short take profit", color=color.new(color.green, 0), style=plot.style_linebr)

var table range4hDashboard = table.new(position.bottom_left, 2, 16, border_width=1)

range4hSetRow(row, labelText, valueText, bgColor) =>
    table.cell(range4hDashboard, 0, row, labelText, text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(range4hDashboard, 1, row, valueText, text_color=color.white, bgcolor=bgColor)

if barstate.islast
    if use4hActive and show4hConfluenceDebugTable
        range4hSetRow(0, "4H mode", range4hFilterMode, color.new(color.blue, 15))
        range4hSetRow(1, "Range high", na(range4hHigh) ? "-" : str.tostring(range4hHigh, format.mintick), color.new(color.red, 35))
        range4hSetRow(2, "Range low", na(range4hLow) ? "-" : str.tostring(range4hLow, format.mintick), color.new(color.green, 35))
        range4hSetRow(3, "Width ATR", na(range4hWidthAtr) ? "-" : str.tostring(range4hWidthAtr, "#.##"), color.new(color.gray, 20))
        range4hSetRow(4, "Last sweep", range4hLastSweep, color.new(color.orange, 20))
        range4hSetRow(5, "Last reclaim", range4hLastReclaim, range4hLastReclaim == "Long" ? color.new(color.green, 20) : range4hLastReclaim == "Short" ? color.new(color.red, 20) : color.new(color.gray, 25))
        range4hSetRow(6, "4H bias", range4hBias, range4hBias == "LONG" ? color.new(color.green, 0) : range4hBias == "SHORT" ? color.new(color.red, 0) : color.new(color.gray, 25))
        range4hSetRow(7, "Recent reclaim L", range4hRecentReclaimLong ? "Yes" : "No", range4hRecentReclaimLong ? color.new(color.green, 25) : color.new(color.gray, 25))
        range4hSetRow(8, "Recent reclaim S", range4hRecentReclaimShort ? "Yes" : "No", range4hRecentReclaimShort ? color.new(color.red, 25) : color.new(color.gray, 25))
        range4hSetRow(9, "Raw Long", str.tostring(range4hRawLongSignalCount), color.new(color.gray, 20))
        range4hSetRow(10, "Raw Short", str.tostring(range4hRawShortSignalCount), color.new(color.gray, 20))
        range4hSetRow(11, "Passed Long", str.tostring(range4hPassedLongSignalCount), color.new(color.green, 30))
        range4hSetRow(12, "Passed Short", str.tostring(range4hPassedShortSignalCount), color.new(color.red, 30))
        range4hSetRow(13, "Blocked Long 4H", str.tostring(range4hBlockedLongSignalCount), color.new(color.gray, 20))
        range4hSetRow(14, "Blocked Short 4H", str.tostring(range4hBlockedShortSignalCount), color.new(color.gray, 20))
        range4hSetRow(15, "Block reason", range4hLastBlockReason, color.new(color.orange, 20))
    else
        table.clear(range4hDashboard, 0, 0, 1, 15)
